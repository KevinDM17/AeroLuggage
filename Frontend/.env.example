# ============================================
# Puerto del servidor de desarrollo de Vite.
# ============================================
PORT=5173

# ============================================
# Backend (REST API)
# ============================================

# URL base del backend REST (sin slash final).
# Ej: http://localhost:8080/api, https://api.midominio.com/api
BACKEND_API_BASE_URL=http://localhost:8080/api

# Tiempo máximo de espera para peticiones REST en milisegundos.
VITE_API_TIMEOUT_MS=60000

# ============================================
# Backend (WebSocket STOMP)
# ============================================

# Host del WebSocket STOMP del back (sin /ws al final, eso lo agrega el cliente).
# El back monta el endpoint en /ws con SockJS.
# Ej: http://localhost:8080, https://api.midominio.com
BACKEND_WS_BASE_URL=http://localhost:8080

# Delay de reconexión del WebSocket en milisegundos.
VITE_WS_RECONNECT_DELAY_MS=5000

# Heartbeat entrante y saliente del WebSocket en milisegundos.
VITE_WS_HEARTBEAT_IN_MS=10000
VITE_WS_HEARTBEAT_OUT_MS=10000

# ============================================
# Mapa
# ============================================

# URL del estilo de mapa de MapLibre.
# Por defecto usa CartoDB dark (sin API key). Si se alcanza el rate limit,
# reemplazar por una URL con API key propia.
VITE_MAP_STYLE_URL=https://basemaps.cartocdn.com/gl/dark-matter-nolabels-gl-style/style.json

# ============================================
# Mock
# ============================================

# Cuando esta en "true" el front usa datos en memoria (sin necesidad del back).
# Cuando esta en "false" o vacío, hace fetch REST + se conecta al WS STOMP.
VITE_USE_MOCK=false

# ============================================
# Polling
# ============================================

# Intervalo de polling en ms (solo para endpoints REST que aún no están via WS).
VITE_POLL_INTERVAL_MS=5000
